{
  "name": "massalia",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @massalia/db db:generate",
    "db:migrate": "pnpm --filter @massalia/db db:migrate",
    "db:seed": "pnpm --filter @massalia/db db:seed",
    "start": "pnpm --filter @massalia/server start",
    "dev:web": "pnpm --filter @massalia/web dev -- --host 127.0.0.1 --port 5174",
    "preview:web": "pnpm --filter @massalia/web build && pnpm --filter @massalia/web exec vite preview --host 127.0.0.1 --port 5175",
    "dev:api": "PORT=3001 pnpm --filter @massalia/server exec tsx src/index.ts",
    "railway:start": "pnpm --filter @massalia/server start"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  },
  "packageManager": "pnpm@10.11.0"
}
