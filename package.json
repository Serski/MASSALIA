{
  "name": "massalia",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @massalia/db db:generate",
    "db:migrate": "pnpm --filter @massalia/db db:migrate",
    "db:seed": "pnpm --filter @massalia/db db:seed",
    "start": "pnpm --filter @massalia/server start",
    "railway:start": "pnpm --filter @massalia/server start"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.1"
  },
  "packageManager": "pnpm@10.11.0"
}
